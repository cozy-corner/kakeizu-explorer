# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# ETL spike: fetched Wikidata dumps (regenerate via scripts/etl-spike/fetch.ts)
/scripts/etl-spike/data/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# brainstorming visual companion (ephemeral mockups)
.superpowers/

# pr-reviews / pr-tasks intermediate files (regenerate from the PR)
/PR-*-reviews.md
/PR-*-tasks.md
